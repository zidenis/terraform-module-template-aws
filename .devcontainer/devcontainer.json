{
	"name": "Terraform Root Module for AWS",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"remoteUser": "vscode",
	"workspaceMount": "source=terraform-vol,target=/home/vscode/workspace,type=volume",
	"workspaceFolder": "/home/vscode/workspace",
	"mounts": [
    	"source=${localWorkspaceFolder},target=/tmp/src,type=bind,consistency=cached"
    ],
	"postCreateCommand": "tenv terraform install $(head /tmp/src/.terraform-version) && rsync -a /tmp/src/ ${HOME}/workspace/ && sudo chown -R vscode:vscode ${HOME}/workspace",
	"postStartCommand": "nohup ${HOME}/sync-dirs.sh > ${HOME}/sync-dirs.log 2>&1 &",
	"customizations": {
		"vscode": {
			"extensions": [
				"hashicorp.terraform",
				"davidanson.vscode-markdownlint"
			]
		}
	}
}